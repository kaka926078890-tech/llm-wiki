{
  "name": "llm-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend && tsc",
    "dev": "concurrently -n backend,frontend -c blue,green \"tsx src/index.ts\" \"npm run dev --prefix frontend\"",
    "dev:debug": "concurrently -n backend,frontend -c blue,green \"LLM_WIKI_DEBUG_TOOLS=true LLM_WIKI_DEBUG_MCP=true LLM_WIKI_DEBUG_SECURITY=true tsx src/index.ts\" \"npm run dev --prefix frontend\"",
    "dev:mcp-debug": "concurrently -n backend,frontend -c blue,green \"LLM_WIKI_DEBUG_MCP=true tsx src/index.ts\" \"npm run dev --prefix frontend\"",
    "dev:server": "tsx src/index.ts",
    "dev:server:debug": "LLM_WIKI_DEBUG_TOOLS=true LLM_WIKI_DEBUG_MCP=true LLM_WIKI_DEBUG_SECURITY=true tsx src/index.ts",
    "cbm:init": "node scripts/cbm-init.mjs",
    "cbm:sync": "node scripts/cbm-sync.mjs",
    "cbm:status": "codebase-memory-mcp cli list_projects '{}'",
    "cbm:setup": "npm run sync:code && npm run cbm:init",
    "verify:upgrade": "tsx scripts/verify-upgrade.ts",
    "sync:code": "node scripts/sync-code-repos.mjs",
    "sync:code:full": "node scripts/sync-code-repos.mjs --cbm-sync",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/copy-tree-sitter-grammars.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.2.0",
    "eventsource-parser": "^3.0.0",
    "fastify": "^5.8.5",
    "ignore": "^7.0.5",
    "picomatch": "^4.0.4",
    "undici": "^8.2.0",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "concurrently": "^9.1.2",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
