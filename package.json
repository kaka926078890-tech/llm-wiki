{
  "name": "llm-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend && tsc",
    "dev": "concurrently -n backend,frontend -c blue,green \"tsx src/index.ts\" \"npm run dev --prefix frontend\"",
    "dev:server": "tsx src/index.ts",
    "index": "tsx src/semantic-index.ts",
    "codegraph:init": "node scripts/codegraph-init.mjs",
    "codegraph:sync": "node scripts/codegraph-sync.mjs",
    "codegraph:status": "codegraph status code/chatkit-middleware && codegraph status code/chatkit-web && codegraph status code/finclaw",
    "codegraph:search": "codegraph query -p code",
    "sync:code": "node scripts/sync-code-repos.mjs",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/copy-tree-sitter-grammars.mjs"
  },
  "dependencies": {
    "@colbymchenry/codegraph": "^0.9.9",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^8.2.0",
    "eventsource-parser": "^3.0.0",
    "fastify": "^5.8.5",
    "ignore": "^7.0.5",
    "picomatch": "^4.0.4",
    "undici": "^8.2.0",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "concurrently": "^9.1.2",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
