DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

REPO_CHATKIT_MIDDLEWARE=code/chatkit-middleware
REPO_CHATKIT_WEB=code/chatkit-web
REPO_FINCLAW=code/finclaw

LLM_WIKI_PORT=3001
LLM_WIKI_HOST=127.0.0.1

# Answer profiles: debug | internal | public
LLM_WIKI_AGENT_ANSWER_PROFILE=debug
LLM_WIKI_MCP_ANSWER_PROFILE=public
# listing/architecture questions skip the extra Summary Agent LLM by default; set true to skip for all questions
# LLM_WIKI_MCP_SKIP_SUMMARY=false

# codebase-memory-mcp (structure + on-device semantic embeddings)
LLM_WIKI_CBM_ENABLED=auto
LLM_WIKI_CBM_BINARY=codebase-memory-mcp
LLM_WIKI_CBM_TOP_K=8
# After `npm run sync:code`, run `cbm:sync` automatically (or use sync:code:full)
# LLM_WIKI_CBM_AUTO_SYNC=false

# P0 evidence + run telemetry
LLM_WIKI_EVIDENCE_STRICT=true
LLM_WIKI_EVIDENCE_REFUSE_EMPTY=true
LLM_WIKI_RUN_TELEMETRY_ENABLED=true
# P0-B retrieval: plan-aware tool budget + hard routing
LLM_WIKI_RETRIEVAL_ROUTING_ENABLED=true
# LLM_WIKI_TOOL_BUDGET_TOTAL cannot go below the plan floor — raise it to allow more tools.
LLM_WIKI_TOOL_BUDGET_ENABLED=true
# LLM_WIKI_TOOL_BUDGET_TOTAL=28
LLM_WIKI_TOOL_BUDGET_EMPTY_STOP=3
